generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id             String    @id @default(cuid())
  name           String
  type           String    // "API" | "STOCK"
  isActive       Boolean   @default(true)
  apiUsername    String?
  apiPasswordEnc String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  products       Product[]
  orders         Order[]
}

model SalesChannel {
  id            String   @id @default(cuid())
  name          String
  countryCode   String?
  commissionPct Decimal  @db.Decimal(5,2)
  isActive      Boolean  @default(true)
  webhookIps    String[]
  createdAt     DateTime @default(now())
  orders        Order[]
}

model Product {
  id            String   @id @default(cuid())
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id])
  externalId    String
  name          String
  sku           String   @unique
  purchasePrice Decimal  @db.Decimal(10,4)
  sellingPrice  Decimal  @db.Decimal(10,4)
  marginPct     Decimal  @db.Decimal(5,2) @default(0)
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model ProductSync {
  id              String   @id @default(cuid())
  totalCategories Int      @default(0)
  totalProducts   Int      @default(0)
  syncData        Json     // Senkronize edilen ürünler ve kategoriler
  isActive        Boolean  @default(true) // En son senkronizasyon mu?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id               String       @id @default(cuid())
  idempotencyKey   String       @unique
  channelId        String
  channel          SalesChannel @relation(fields: [channelId], references: [id])
  providerId       String
  provider         Provider     @relation(fields: [providerId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  customerName     String?
  sellingPrice     Decimal      @db.Decimal(10,4)
  purchasePrice    Decimal      @db.Decimal(10,4)
  commissionPct    Decimal      @db.Decimal(5,2)
  commissionAmount Decimal      @db.Decimal(10,4)
  profit           Decimal      @db.Decimal(10,4)
  status           String       @default("PENDING")
  digitalCodeEnc   String?
  providerOrderNo  String?
  customerEmail    String?
  orderedAt        DateTime
  fulfilledAt      DateTime?
  createdAt        DateTime     @default(now())
  currency         String?      @default("TRY")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  passwordHash        String
  role                String    @default("OPERATIONS")
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  auditLogs           AuditLog[]
}

model SelectedProduct {
  id            String   @id @default(cuid())
  productId     String   @unique @map("product_id")
  epinId        String   @map("epin_id")
  epinName      String   @map("epin_name")
  productName   String   @map("product_name")
  purchasePrice Decimal  @db.Decimal(10,4) @map("purchase_price")
  sellingPrice  Decimal  @db.Decimal(10,4) @map("selling_price")
  marginPct     Decimal  @db.Decimal(5,2) @default(15) @map("margin_pct")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("selected_products")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      Json     @default("{}")
  ip        String
  createdAt DateTime @default(now())
}
